# =========================================
# MyCoinCard Cash — Environment Variables
# =========================================

# Application
NEXT_PUBLIC_APP_NAME="MyCoinCard Cash"
NEXT_PUBLIC_APP_URL="https://mycoincard.cash"
NODE_ENV="development"

# Database (Prisma) — use PostgreSQL in prod, SQLite for local dev
DATABASE_URL="file:./dev.db"
# DATABASE_URL="postgresql://user:password@localhost:5432/mycoincard?schema=public"

# Auth
JWT_SECRET="change-me-to-a-long-random-string-min-32-chars"
JWT_EXPIRES_IN="7d"
SESSION_COOKIE_NAME="mcc_session"

# Email (any SMTP / Resend / Postmark)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM="no-reply@mycoincard.cash"

# Cloudinary (KYC + receipt uploads)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# SMS
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM=""

# Payments
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
PAYSTACK_SECRET_KEY=""
FLUTTERWAVE_SECRET_KEY=""

# Optional: Credit score / KYC providers
CREDIT_SCORE_API_KEY=""
KYC_PROVIDER_API_KEY=""

# Optional: AI assistant
OPENAI_API_KEY=""

# Security
RATE_LIMIT_PER_MIN="60"
CSRF_SECRET="another-long-random-string"
